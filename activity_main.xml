<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="30dp">

    <!-- 主标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:gravity="center"
        android:text="NoteMind-智记"
        android:textSize="26sp"
        android:textStyle="bold" />

    <!-- 标语：在标题右下方 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:text="智记 - 更懂你的知己"
        android:textColor="#6C757D"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btn_take_photo"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/btn_dark_gradient"
        android:text="拍照识别"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btn_gallery"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/btn_dark_gradient"
        android:text="相册识别"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btn_input_text"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/btn_dark_gradient"
        android:text="文本识别"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btn_show_list"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/btn_clean"
        android:text="让朕看看!"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btn_knowledge_atom"
        android:layout_width="328dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/btn_dark_gradient"
        android:text="原子智图"
        android:textSize="18sp" />

</LinearLayout>